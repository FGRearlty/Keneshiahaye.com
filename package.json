{
  "scripts": {
    "build:css": "tailwindcss -i src/input.css -o css/styles.css --minify",
    "dev:css": "tailwindcss -i src/input.css -o css/styles.css --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:html": "html-validate '*.html' 'blog/*.html' 'areas/*.html'",
    "test:lint": "eslint 'ghl-integration/**/*.js' 'tests/**/*.js' 'server.js' 'functions/**/*.js'",
    "test:all": "vitest run && html-validate '*.html' 'blog/*.html' 'areas/*.html' && eslint 'ghl-integration/**/*.js' 'tests/**/*.js' 'server.js' 'functions/**/*.js' && playwright test --project=chromium",
    "validate:redirects": "node scripts/validate-redirects.js",
    "validate:headers": "node scripts/validate-headers.js",
    "validate:links": "node scripts/check-links.js",
    "validate:all": "node scripts/validate-redirects.js && node scripts/validate-headers.js && node scripts/check-links.js"
  },
  "dependencies": {
    "mammoth": "^1.11.0",
    "pdfkit": "^0.17.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.1",
    "eslint": "^10.0.3",
    "html-validate": "^10.11.1",
    "jsdom": "^28.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "vitest": "^4.1.0"
  }
}
