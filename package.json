{
  "scripts": {
    "build:css": "tailwindcss -i src/input.css -o css/styles.css --minify",
    "dev:css": "tailwindcss -i src/input.css -o css/styles.css --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:html": "html-validate '*.html' 'blog/*.html' 'areas/*.html'",
    "test:all": "vitest run && html-validate '*.html' 'blog/*.html' 'areas/*.html'"
  },
  "dependencies": {
    "mammoth": "^1.11.0",
    "pdfkit": "^0.17.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.1",
    "html-validate": "^10.11.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "vitest": "^4.1.0"
  }
}
