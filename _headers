/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # A basic Content Security Policy (CSP). This is a starting point and
  # should be tested and expanded based on your site's specific needs.
  # It allows self, Google Fonts, and Google Tag Manager.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://www.googletagmanager.com https://keneshia-haye-form-handler.jutsuxx.workers.dev; frame-src 'self' https://www.googletagmanager.com;